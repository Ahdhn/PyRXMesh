include_guard(GLOBAL)

set(PYRXMESH_VERSION "@PROJECT_VERSION@")
set(PYRXMESH_PLUGIN_ABI_VERSION "@PYRXMESH_PLUGIN_ABI_VERSION@")
set(PYRXMESH_BUILD_CONFIG_TAG "@PYRXMESH_BUILD_CONFIG_TAG@")
set(PYRXMESH_RXMESH_GIT_REPO "@PYRXMESH_RXMESH_GIT_REPO@")
set(PYRXMESH_RXMESH_GIT_TAG "@PYRXMESH_RXMESH_GIT_TAG@")
set(PYRXMESH_RXMESH_SOURCE_DIR "@PYRXMESH_RXMESH_SOURCE_DIR@")
set(PYRXMESH_USE_POLYSCOPE "@PYRXMESH_USE_POLYSCOPE@")
set(PYRXMESH_BUILD_RXMESH_TESTS "@PYRXMESH_BUILD_RXMESH_TESTS@")
set(PYRXMESH_BUILD_RXMESH_APPS "@PYRXMESH_BUILD_RXMESH_APPS@")
set(PYRXMESH_USE_DOUBLE "@PYRXMESH_USE_DOUBLE@")
set(PYRXMESH_USE_CUDSS "@PYRXMESH_USE_CUDSS@")
set(PYRXMESH_USE_SUITESPARSE "@PYRXMESH_USE_SUITESPARSE@")
set(PYRXMESH_CUDA_ARCHITECTURES "@CMAKE_CUDA_ARCHITECTURES@")

get_filename_component(_PYRXMESH_PACKAGE_DIR "${CMAKE_CURRENT_LIST_DIR}/.." ABSOLUTE)
set(_PYRXMESH_INCLUDE_DIR "${_PYRXMESH_PACKAGE_DIR}/include")
set(_PYRXMESH_THIRD_PARTY_INCLUDE_DIR "${_PYRXMESH_PACKAGE_DIR}/third_party/include")
set(_PYRXMESH_LIBRARY_DIR "${_PYRXMESH_PACKAGE_DIR}/lib")
set(_PYRXMESH_RXMESH_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}RXMesh${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
set(_PYRXMESH_METIS_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}metis${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
set(_PYRXMESH_GKLIB_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}GKlib${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
set(_PYRXMESH_POLYSCOPE_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}polyscope${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
set(_PYRXMESH_IMGUI_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}imgui${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
set(_PYRXMESH_GLAD_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}glad${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
set(_PYRXMESH_GLFW_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}glfw3${CMAKE_STATIC_LIBRARY_SUFFIX}"
)
if(NOT EXISTS "${_PYRXMESH_GLFW_LIBRARY}")
    set(_PYRXMESH_GLFW_LIBRARY
        "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}glfw${CMAKE_STATIC_LIBRARY_SUFFIX}"
    )
endif()
set(_PYRXMESH_STB_LIBRARY
    "${_PYRXMESH_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}stb${CMAKE_STATIC_LIBRARY_SUFFIX}"
)

if(NOT TARGET pyrxmesh::plugin_api)
    add_library(pyrxmesh::plugin_api INTERFACE IMPORTED)
    set_target_properties(pyrxmesh::plugin_api PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_PACKAGE_DIR}/include"
        INTERFACE_COMPILE_DEFINITIONS
            "PYRXMESH_PLUGIN_ABI_VERSION=${PYRXMESH_PLUGIN_ABI_VERSION};PYRXMESH_BUILD_CONFIG=\"${PYRXMESH_BUILD_CONFIG_TAG}\""
    )
endif()

if(NOT DEFINED CMAKE_CUDA_ARCHITECTURES AND NOT "${PYRXMESH_CUDA_ARCHITECTURES}" STREQUAL "")
    set(CMAKE_CUDA_ARCHITECTURES "${PYRXMESH_CUDA_ARCHITECTURES}")
endif()

find_package(CUDAToolkit REQUIRED)
find_package(OpenMP)

if(EXISTS "${_PYRXMESH_GKLIB_LIBRARY}" AND NOT TARGET GKlib)
    add_library(GKlib STATIC IMPORTED GLOBAL)
    set_target_properties(GKlib PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_GKLIB_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
    )
endif()

if(TARGET GKlib AND NOT TARGET GKlib::GKlib)
    add_library(GKlib::GKlib INTERFACE IMPORTED GLOBAL)
    target_link_libraries(GKlib::GKlib INTERFACE GKlib)
endif()

if(EXISTS "${_PYRXMESH_METIS_LIBRARY}" AND NOT TARGET metis)
    set(_PYRXMESH_METIS_LINK_LIBRARIES "")
    if(TARGET GKlib)
        list(APPEND _PYRXMESH_METIS_LINK_LIBRARIES GKlib)
    endif()

    add_library(metis STATIC IMPORTED GLOBAL)
    set_target_properties(metis PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_METIS_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
        INTERFACE_COMPILE_DEFINITIONS "IDXTYPEWIDTH=32;REALTYPEWIDTH=32"
        INTERFACE_LINK_LIBRARIES "${_PYRXMESH_METIS_LINK_LIBRARIES}"
    )
endif()

if(EXISTS "${_PYRXMESH_IMGUI_LIBRARY}" AND NOT TARGET imgui)
    add_library(imgui STATIC IMPORTED GLOBAL)
    set_target_properties(imgui PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_IMGUI_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
    )
endif()

if(EXISTS "${_PYRXMESH_GLAD_LIBRARY}" AND NOT TARGET glad)
    add_library(glad STATIC IMPORTED GLOBAL)
    set_target_properties(glad PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_GLAD_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
    )
endif()

if(EXISTS "${_PYRXMESH_GLFW_LIBRARY}" AND NOT TARGET glfw)
    add_library(glfw STATIC IMPORTED GLOBAL)
    set_target_properties(glfw PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_GLFW_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
    )
endif()

if(EXISTS "${_PYRXMESH_STB_LIBRARY}" AND NOT TARGET stb)
    add_library(stb STATIC IMPORTED GLOBAL)
    set_target_properties(stb PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_STB_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
    )
endif()

if(EXISTS "${_PYRXMESH_POLYSCOPE_LIBRARY}" AND NOT TARGET polyscope)
    set(_PYRXMESH_POLYSCOPE_LINK_LIBRARIES "")
    foreach(_PYRXMESH_POLYSCOPE_DEP imgui glad glfw stb)
        if(TARGET ${_PYRXMESH_POLYSCOPE_DEP})
            list(APPEND _PYRXMESH_POLYSCOPE_LINK_LIBRARIES ${_PYRXMESH_POLYSCOPE_DEP})
        endif()
    endforeach()

    add_library(polyscope STATIC IMPORTED GLOBAL)
    set_target_properties(polyscope PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_POLYSCOPE_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "${_PYRXMESH_POLYSCOPE_LINK_LIBRARIES}"
    )
endif()

set(_PYRXMESH_RXMESH_LINK_LIBRARIES CUDA::cusparse CUDA::cusolver)
if(TARGET metis)
    list(APPEND _PYRXMESH_RXMESH_LINK_LIBRARIES metis)
endif()
if(TARGET polyscope)
    list(APPEND _PYRXMESH_RXMESH_LINK_LIBRARIES polyscope)
endif()
if(OpenMP_CXX_FOUND)
    list(APPEND _PYRXMESH_RXMESH_LINK_LIBRARIES OpenMP::OpenMP_CXX)
endif()

set(_PYRXMESH_RXMESH_COMPILE_DEFINITIONS
    "INPUT_DIR=${_PYRXMESH_PACKAGE_DIR}/input/"
    "OUTPUT_DIR=${_PYRXMESH_PACKAGE_DIR}/output/"
    EIGEN_ALLOW_UNALIGNED_SCALARS
    EIGEN_DEFAULT_DENSE_INDEX_TYPE=int
)
if(PYRXMESH_USE_POLYSCOPE)
    list(APPEND _PYRXMESH_RXMESH_COMPILE_DEFINITIONS USE_POLYSCOPE)
endif()
if(PYRXMESH_USE_DOUBLE)
    list(APPEND _PYRXMESH_RXMESH_COMPILE_DEFINITIONS RXMESH_USE_DOUBLE)
endif()
if(PYRXMESH_USE_SUITESPARSE)
    list(APPEND _PYRXMESH_RXMESH_COMPILE_DEFINITIONS USE_SUITESPARSE)
endif()

if(NOT EXISTS "${_PYRXMESH_RXMESH_LIBRARY}")
    message(FATAL_ERROR
        "PyRXMesh was installed without the RXMesh library required for "
        "custom CUDA plugins: ${_PYRXMESH_RXMESH_LIBRARY}"
    )
endif()

if(NOT TARGET RXMesh)
    add_library(RXMesh STATIC IMPORTED GLOBAL)
    set_target_properties(RXMesh PROPERTIES
        IMPORTED_LOCATION "${_PYRXMESH_RXMESH_LIBRARY}"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CUDA;CXX"
        INTERFACE_COMPILE_FEATURES cxx_std_17
        INTERFACE_COMPILE_DEFINITIONS "${_PYRXMESH_RXMESH_COMPILE_DEFINITIONS}"
        INTERFACE_INCLUDE_DIRECTORIES "${_PYRXMESH_INCLUDE_DIR};${_PYRXMESH_THIRD_PARTY_INCLUDE_DIR};${CUDAToolkit_INCLUDE_DIRS}"
        INTERFACE_LINK_LIBRARIES "${_PYRXMESH_RXMESH_LINK_LIBRARIES}"
        INTERFACE_POSITION_INDEPENDENT_CODE ON
    )
endif()

find_package(Python3 REQUIRED COMPONENTS Interpreter Development.Module)

if(NOT TARGET pybind11::module)
    find_package(pybind11 CONFIG REQUIRED)
endif()

function(pyrxmesh_add_plugin target)
    pybind11_add_module(${target} MODULE ${ARGN})
    target_link_libraries(${target} PRIVATE RXMesh pyrxmesh::plugin_api)
    target_compile_features(${target} PRIVATE cxx_std_17)
    target_compile_options(${target} PRIVATE
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:MSVC>>:-D_SCL_SECURE_NO_WARNINGS>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:MSVC>>:/openmp:experimental>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:MSVC>>:/MP>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:MSVC>>:/std:c++17>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:MSVC>>:/bigobj>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:GNU>>:-Wall>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:GNU>>:-m64>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:GNU>>:-fopenmp>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:GNU>>:-O3>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:GNU>>:-std=c++17>
        $<$<AND:$<COMPILE_LANGUAGE:CXX>,$<CXX_COMPILER_ID:GNU>>:-Wno-unused-function>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xcompiler=$<$<CXX_COMPILER_ID:GNU>:-rdynamic,-Wall,-fopenmp,-O3,-Wno-unused-function>>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xcompiler=$<$<CXX_COMPILER_ID:MSVC>:/openmp:experimental,/MP,/std:c++17,/bigobj,/Zi>>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xcudafe=--display_error_number>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xcudafe=--diag_suppress=177>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xcudafe=--diag_suppress=174>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xcudafe=--diag_suppress=20054>
        $<$<COMPILE_LANGUAGE:CUDA>:-rdc=true>
        $<$<COMPILE_LANGUAGE:CUDA>:-lineinfo>
        $<$<COMPILE_LANGUAGE:CUDA>:--expt-extended-lambda>
        $<$<AND:$<COMPILE_LANGUAGE:CUDA>,$<CXX_COMPILER_ID:GNU>>:-O3>
        $<$<COMPILE_LANGUAGE:CUDA>:--expt-relaxed-constexpr>
        $<$<COMPILE_LANGUAGE:CUDA>:-Xptxas=-warn-spills>
        $<$<COMPILE_LANGUAGE:CUDA>:--resource-usage>
        $<$<COMPILE_LANGUAGE:CUDA>:--ptxas-options=-v>
    )
    target_compile_definitions(${target}
        PRIVATE PYRXMESH_PLUGIN_ABI_VERSION=${PYRXMESH_PLUGIN_ABI_VERSION}
        PRIVATE PYRXMESH_BUILD_CONFIG="${PYRXMESH_BUILD_CONFIG_TAG}"
    )
    set_target_properties(${target} PROPERTIES
        CUDA_SEPARABLE_COMPILATION ON
        CUDA_RESOLVE_DEVICE_SYMBOLS ON
    )
    if(WIN32)
        target_compile_definitions(${target}
            PRIVATE _USE_MATH_DEFINES
            PRIVATE NOMINMAX
            PRIVATE _CRT_SECURE_NO_WARNINGS
        )
    endif()
endfunction()
